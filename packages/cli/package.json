  "type": "module",
  "author": "Mario Ivančić",
  "license": "MIT",
  "scripts": {
    "prepack": "node scripts/prepack.mjs",
    "postpack": "node scripts/postpack.mjs"
  },
  "bin": {
    "cmsbar": "bin/cmsbar.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmsbar/cmsbar.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/cmsbar/cmsbar#readme",
  "bugs": {
    "url": "https://github.com/cmsbar/cmsbar/issues"
  },
  "files": ["bin", "template", "examples"],
  "engines": {
    "node": ">=18"
  },
  "keywords": ["cms", "git", "github", "inline-editing", "nextjs", "react-router", "tanstack-start", "vite", "astro", "sveltekit", "nuxt"]
