{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": false,
    "paths": {
      "@/cms.config": ["./template/cms.config"],
      "@/lib/*": ["./template/lib/*"],
      "@/components/*": ["./template/components/*"]
    }
  },
  "include": ["template/**/*.ts", "template/**/*.tsx", "tests/**/*.ts"],
  "exclude": ["node_modules"]
}
