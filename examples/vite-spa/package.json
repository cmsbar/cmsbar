    "tailwind-merge": "^3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/bcryptjs": "^2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "tailwindcss": "^4",
    "tsconfig-paths": "^4.2.0",
