# Dependencies + build output
node_modules/
.output/
.tanstack/
.nitro/
dist/
build/
package-lock.json
*.tsbuildinfo
.DS_Store

# Generated by the TanStack Start Vite plugin on first dev/build.
src/routeTree.gen.ts

# Env files: commit only the template (.env.example). Copy it to .env.local and
# fill in your CMSBar secrets to run the editor (root .gitignore handles .env*).
!.env.example

# CMS core is assembled by `npm run setup` (copied from ../../template), never
# committed - so this example never forks the core. Only the host-specific
# wiring under src/cmsbar, src/routes, src/router.tsx, src/cms.config.ts,
# src/content/, src/styles/app.css lives in git.
/src/components/cmsbar/
/src/lib/cmsbar/
/src/lib/content.ts
/src/styles/cmsbar.css
