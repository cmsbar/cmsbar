{
  "name": "cmsbar-monorepo",
  "version": "0.2.1",
  "private": true,
  "description": "CMSBar - the Git-as-CMS bar you drop into your own codebase.",
  "author": "Mario Ivančić",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmsbar/cmsbar.git"
  },
  "homepage": "https://cmsbar.com",
  "bugs": {
    "url": "https://github.com/cmsbar/cmsbar/issues"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"template/**/*.{ts,tsx,css}\" \"packages/**/*.mjs\" \"tests/**/*.ts\"",
    "check": "npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "next": "^16.1.3",
    "prettier": "^3.3.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
